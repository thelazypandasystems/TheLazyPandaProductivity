<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>The Lazy Panda Productivity</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --green: #3a6b4a;
    --green-light: #e8f0ea;
    --green-mid: #b5d0bc;
    --red: #c0392b;
    --red-light: #f9eae8;
    --black: #111;
    --gray: #555;
    --gray-light: #f5f5f3;
    --white: #fff;
    --radius: 16px;
    --font-head: 'Noto Serif JP', serif;
    --font-body: 'DM Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--white);
    color: var(--black);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 999;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e8ede9;
    padding: 1rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-head); font-weight: 700;
    font-size: 1.05rem; color: var(--black); text-decoration: none;
  }
  .nav-logo img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { text-decoration: none; color: var(--gray); font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--green); }
  .nav-cta {
    background: var(--green); color: var(--white);
    padding: 0.5rem 1.25rem; border-radius: 50px;
    text-decoration: none; font-size: 0.875rem; font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }
  .nav-cta:hover { background: #2e5a3c; transform: translateY(-1px); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--black); border-radius: 2px; }

  /* SECTIONS */
  section { padding: 6rem 2rem; }
  .container { max-width: 1000px; margin: 0 auto; }
  .section-label {
    display: inline-block;
    font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--green); font-weight: 600;
    background: var(--green-light); padding: 0.3rem 0.9rem;
    border-radius: 50px; margin-bottom: 1.25rem;
  }
  h2.section-title {
    font-family: var(--font-head); font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700; line-height: 1.25; margin-bottom: 1rem; color: var(--black);
  }
  .section-sub { font-size: 1.05rem; color: var(--gray); max-width: 580px; margin-bottom: 3rem; }

  /* HERO */
  #hero {
    min-height: 90vh; display: flex; align-items: center;
    background: linear-gradient(160deg, #f7faf7 0%, #fff 60%, #fdf6f5 100%);
    padding: 5rem 2rem;
  }
  .hero-inner {
    max-width: 1000px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
  }
  .hero-text {}
  .hero-eyebrow {
    font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--red); font-weight: 600; margin-bottom: 1rem;
    display: flex; align-items: center; gap: 8px;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 28px; height: 2px; background: var(--red); border-radius: 2px; }
  h1 {
    font-family: var(--font-head);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700; line-height: 1.18;
    color: var(--black); margin-bottom: 1.25rem;
  }
  h1 em { font-style: normal; color: var(--green); }
  .hero-sub { font-size: 1.1rem; color: var(--gray); margin-bottom: 2.5rem; line-height: 1.7; }
  .btn-group { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--green); color: var(--white);
    padding: 0.85rem 2rem; border-radius: 50px;
    text-decoration: none; font-size: 0.95rem; font-weight: 600;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(58,107,74,0.25);
  }
  .btn-primary:hover { background: #2e5a3c; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(58,107,74,0.3); }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 6px;
    background: transparent; color: var(--green);
    border: 1.5px solid var(--green);
    padding: 0.85rem 2rem; border-radius: 50px;
    text-decoration: none; font-size: 0.95rem; font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-outline:hover { background: var(--green-light); transform: translateY(-2px); }
  .hero-visual {
    display: flex; justify-content: center; align-items: center;
  }
  .hero-logo-wrap {
    position: relative; width: 300px; height: 300px;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-logo-bg {
    position: absolute; inset: 0; border-radius: 50%;
    background: radial-gradient(circle, #e8f5eb 0%, #f7fdf8 70%, transparent 100%);
    animation: pulse 4s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{transform:scale(1);opacity:0.8} 50%{transform:scale(1.05);opacity:1} }
  .hero-logo-img { width: 240px; height: 240px; border-radius: 50%; object-fit: cover; position: relative; z-index: 1; }
  .hero-stats {
    display: flex; gap: 2rem; margin-top: 2.5rem; flex-wrap: wrap;
  }
  .stat { }
  .stat-num { font-family: var(--font-head); font-size: 1.8rem; font-weight: 700; color: var(--green); }
  .stat-label { font-size: 0.8rem; color: var(--gray); }

  /* PROBLEM */
  #problem { background: var(--gray-light); }
  .problem-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 2rem;
  }
  .problem-card {
    background: var(--white); border-radius: var(--radius);
    padding: 2rem 1.75rem;
    border: 1px solid #e8e8e8;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .problem-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.07); }
  .problem-icon { font-size: 2rem; margin-bottom: 1rem; }
  .problem-card h3 { font-family: var(--font-head); font-size: 1.1rem; margin-bottom: 0.5rem; }
  .problem-card p { font-size: 0.9rem; color: var(--gray); }

  /* SOLUTION */
  #solution { }
  .solution-steps { display: flex; flex-direction: column; gap: 0; margin-top: 1rem; }
  .step {
    display: flex; gap: 2rem; align-items: flex-start;
    padding: 2.5rem 0; border-bottom: 1px solid #eee;
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    flex-shrink: 0; width: 52px; height: 52px;
    background: var(--green); color: var(--white);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-head); font-size: 1.25rem; font-weight: 700;
  }
  .step-text h3 { font-family: var(--font-head); font-size: 1.2rem; margin-bottom: 0.4rem; }
  .step-text p { color: var(--gray); font-size: 0.95rem; }

  /* PRODUCTS */
  #products { background: var(--gray-light); }
  .products-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 0;
  }
  .product-card {
    background: var(--white); border-radius: var(--radius);
    padding: 2rem; border: 1px solid #e8e8e8;
    display: flex; flex-direction: column; gap: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative; overflow: hidden;
  }
  .product-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 3px; background: var(--green);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .product-card:hover::before { transform: scaleX(1); }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.09); }
  .product-card.featured { border-color: var(--green); }
  .featured-badge {
    position: absolute; top: 1rem; right: 1rem;
    background: var(--green); color: var(--white);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 50px;
  }
  .product-name { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; }
  .product-price {
    font-size: 1.6rem; font-weight: 700;
    color: var(--green); font-family: var(--font-head);
  }
  .product-desc { font-size: 0.9rem; color: var(--gray); flex: 1; }
  .btn-buy {
    display: block; text-align: center;
    background: var(--black); color: var(--white);
    padding: 0.75rem 1.5rem; border-radius: 50px;
    text-decoration: none; font-size: 0.875rem; font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-buy:hover { background: var(--green); transform: translateY(-1px); }

  /* GILBERT */
  #gilbert { background: linear-gradient(135deg, #f0f7f1 0%, #fff 100%); }
  .gilbert-ui {
    background: var(--white); border-radius: 20px;
    border: 1px solid #dde8de;
    overflow: hidden; max-width: 700px; margin: 0 auto;
    box-shadow: 0 8px 40px rgba(58,107,74,0.1);
  }
  .gilbert-header {
    background: var(--green); padding: 1.25rem 1.75rem;
    display: flex; align-items: center; gap: 12px;
  }
  .gilbert-avatar {
    width: 42px; height: 42px; background: rgba(255,255,255,0.2);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
  }
  .gilbert-info { color: var(--white); }
  .gilbert-info strong { display: block; font-size: 1rem; font-weight: 600; }
  .gilbert-info span { font-size: 0.8rem; opacity: 0.8; }
  .gilbert-dot {
    width: 8px; height: 8px; background: #7deda8; border-radius: 50%;
    margin-left: auto; animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .gilbert-messages {
    min-height: 220px; max-height: 300px; overflow-y: auto;
    padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;
  }
  .msg { display: flex; gap: 10px; align-items: flex-start; }
  .msg-avatar {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
  }
  .msg.bot .msg-avatar { background: var(--green-light); }
  .msg.user { flex-direction: row-reverse; }
  .msg.user .msg-avatar { background: #f0f0f0; }
  .msg-bubble {
    padding: 0.75rem 1rem; border-radius: 14px;
    font-size: 0.9rem; max-width: 80%; line-height: 1.5;
  }
  .msg.bot .msg-bubble { background: var(--green-light); color: var(--black); border-bottom-left-radius: 4px; }
  .msg.user .msg-bubble { background: var(--black); color: var(--white); border-bottom-right-radius: 4px; }
  .gilbert-input-area { padding: 1.25rem; border-top: 1px solid #eee; display: flex; gap: 0.75rem; }
  #gilbert-input {
    flex: 1; padding: 0.75rem 1.1rem; border-radius: 50px;
    border: 1.5px solid #dde8de; font-family: var(--font-body); font-size: 0.9rem;
    outline: none; transition: border-color 0.2s;
  }
  #gilbert-input:focus { border-color: var(--green); }
  #gilbert-send {
    background: var(--green); color: var(--white);
    border: none; cursor: pointer; padding: 0.75rem 1.5rem;
    border-radius: 50px; font-family: var(--font-body); font-size: 0.875rem;
    font-weight: 600; transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  #gilbert-send:hover { background: #2e5a3c; transform: translateY(-1px); }
  .typing { display: flex; gap: 4px; padding: 0.75rem 1rem; }
  .typing span {
    width: 8px; height: 8px; background: var(--green-mid);
    border-radius: 50%; animation: bounce 1.2s infinite;
  }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-8px)} }

  /* AMAZON */
  #amazon { background: var(--gray-light); }
  .amazon-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;
  }
  .amazon-card {
    background: var(--white); border-radius: var(--radius);
    padding: 1.75rem 1.5rem; border: 1px solid #e8e8e8;
    display: flex; flex-direction: column; gap: 0.75rem;
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
  }
  .amazon-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.07); }
  .amazon-icon { font-size: 2.5rem; margin-bottom: 0.25rem; }
  .amazon-card h3 { font-family: var(--font-head); font-size: 1rem; font-weight: 700; }
  .amazon-card p { font-size: 0.85rem; color: var(--gray); flex: 1; }
  .btn-amazon {
    display: block; text-align: center;
    background: #ff9800; color: var(--white);
    padding: 0.65rem 1.25rem; border-radius: 50px;
    text-decoration: none; font-size: 0.85rem; font-weight: 600;
    transition: background 0.2s;
  }
  .btn-amazon:hover { background: #e68900; }
  .amazon-disclaimer {
    font-size: 0.78rem; color: #aaa; text-align: center; margin-top: 1.5rem;
  }

  /* ABOUT */
  #about { }
  .about-inner {
    display: grid; grid-template-columns: 1fr 1.6fr; gap: 4rem; align-items: center;
  }
  .about-logo-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .about-logo-img { width: 180px; height: 180px; border-radius: 50%; object-fit: cover; border: 3px solid var(--green-mid); }
  .about-name { font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; color: var(--green); }
  .about-text p { color: var(--gray); font-size: 0.97rem; margin-bottom: 1rem; }
  .about-text p:last-child { margin-bottom: 0; }
  .about-diff {
    margin-top: 1.5rem; padding: 1.5rem;
    background: var(--green-light); border-radius: var(--radius);
    border-left: 3px solid var(--green);
  }
  .about-diff strong { display: block; color: var(--green); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .about-diff p { color: var(--black); font-size: 0.9rem; margin: 0; }

  /* FINAL CTA */
  #cta {
    background: var(--green);
    text-align: center;
    padding: 7rem 2rem;
  }
  #cta h2 {
    font-family: var(--font-head); font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700; color: var(--white); margin-bottom: 1rem;
  }
  #cta p { color: rgba(255,255,255,0.8); font-size: 1.05rem; margin-bottom: 2.5rem; }
  .cta-btns { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .btn-white {
    background: var(--white); color: var(--green);
    padding: 0.9rem 2.2rem; border-radius: 50px;
    text-decoration: none; font-weight: 700; font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
  .btn-outline-white {
    background: transparent; color: var(--white);
    border: 2px solid rgba(255,255,255,0.6);
    padding: 0.9rem 2.2rem; border-radius: 50px;
    text-decoration: none; font-weight: 600; font-size: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,0.1); }

  /* FOOTER */
  footer {
    text-align: center; padding: 2.5rem 2rem;
    background: var(--black); color: #888;
    font-size: 0.85rem;
  }
  footer a { color: var(--green-mid); text-decoration: none; }

  /* MOBILE */
  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-visual { order: -1; }
    .hero-logo-wrap { width: 200px; height: 200px; }
    .hero-logo-img { width: 160px; height: 160px; }
    .about-inner { grid-template-columns: 1fr; gap: 2rem; }
    .about-logo-wrap { flex-direction: row; }
    section { padding: 4rem 1.25rem; }
    .step { gap: 1.25rem; }
    nav { padding: 1rem 1.25rem; }
  }
</style>
</head>
