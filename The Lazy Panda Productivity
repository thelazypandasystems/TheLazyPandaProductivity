<script>
// Load uploaded logo into img tags
(function() {
  const logoSrc = "data:image/jpeg;base64,";
  ['hero-logo-img','about-logo-img','nav-logo-img'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.src = logoSrc;
