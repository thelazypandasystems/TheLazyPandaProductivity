})();

// Mobile menu
function toggleMenu(btn) {
  let menu = document.querySelector('.mobile-menu');
  if (menu) { menu.remove(); return; }
  menu = document.createElement('div');
  menu.className = 'mobile-menu';
  menu.style.cssText = 'position:fixed;top:65px;left:0;right:0;background:#fff;border-bottom:1px solid #e8ede9;padding:1.5rem;z-index:998;display:flex;flex-direction:column;gap:1rem;';
  const links = [['#problem','Problem'],['#solution','System'],['#products','Products'],['#gilbert','Gilbert'],['#about','About']];
  links.forEach(([href, label]) => {
    const a = document.createElement('a');
    a.href = href; a.textContent = label;
    a.style.cssText = 'font-size:1.05rem;color:#333;text-decoration:none;padding:0.5rem 0;border-bottom:1px solid #f0f0f0;';
    a.onclick = () => menu.remove();
    menu.appendChild(a);
  });
  document.body.appendChild(menu);
}

// Gilbert AI
const responses = {
  procrastinat: [
    "Procrastination usually means the task feels too big or unclear. Break it into the smallest possible next step. What's the tiniest thing you could do in the next 5 minutes?",
    "Try the 2-minute rule: if it takes under 2 minutes, do it now. For bigger tasks, just commit to starting for 5 minutes. You'll usually keep going.",
    "Procrastination is often avoidance of discomfort, not laziness. Identify what feels uncomfortable about the task, then make it as easy as possible to start."
  ],
  focus: [
    "To improve focus, reduce decisions. Lay out your 3 most important tasks the night before. When you sit down, you already know what to do — no energy wasted deciding.",
    "Try working in 25-minute blocks with 5-minute breaks. It's called the Pomodoro Technique and it's one of the most effective focus tools out there.",
    "Clear your workspace before you start. Physical clutter creates mental clutter. A clean desk = a calmer mind."
  ],
  overwhelm: [
    "When overwhelmed, do a brain dump: write down everything on your mind. Then pick just ONE thing to do next. The rest can wait.",
    "Overwhelm usually comes from trying to hold everything in your head. Get it all on paper first, then prioritize ruthlessly. 3 tasks max per day.",
    "Take a 10-minute reset: step away, breathe, and come back to the question — 'What's the ONE thing that would make today a win?'"
  ],
  routine: [
    "The best routine is the one you'll actually do. Start with just 2 habits — one in the morning, one at night. Keep it under 10 minutes total.",
    "Anchor new habits to existing ones. After coffee → write your 3 tasks. Before bed → close your laptop and do a 5-minute review.",
    "Consistency beats intensity. A 5-minute routine done every day beats a 2-hour system done once a week."
  ],
  task: [
    "Pick your top 3 tasks for the day — nothing more. Ask yourself: 'If I only got 3 things done today, what would make the day a success?'",
    "Not all tasks are equal. Use the 80/20 rule: 20% of your tasks produce 80% of your results. Find those and do them first.",
    "Time-block your 3 main tasks in the morning when your energy is highest. Everything else fits in the gaps."
  ],
  default: [
    "Great question! The Lazy Panda Productivity way is always to simplify first. What's the smallest version of this you could tackle today?",
    "I'd suggest starting with your 3 most important tasks and working backward from there. What's the outcome you actually want?",
    "Simplicity is the key. Instead of thinking about the whole system, just ask: what's one thing I can do right now to move forward?",
    "The Lazy Panda Productivity approach: do less, but do it consistently. What does 'enough' look like for you today?"
  ]
};

function getResponse(msg) {
  const m = msg.toLowerCase();
  if (m.includes('procrastinat') || m.includes('putting off') || m.includes('delay')) return pick(responses.procrastinat);
  if (m.includes('focus') || m.includes('distract') || m.includes('concentrat')) return pick(responses.focus);
  if (m.includes('overwhelm') || m.includes('too much') || m.includes('stress') || m.includes('anxious')) return pick(responses.overwhelm);
  if (m.includes('routine') || m.includes('habit') || m.includes('morning') || m.includes('night')) return pick(responses.routine);
  if (m.includes('task') || m.includes('todo') || m.includes('list') || m.includes('priorit')) return pick(responses.task);
  return pick(responses.default);
}

function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

function addMsg(text, type) {
  const msgs = document.getElementById('gilbert-messages');
  const div = document.createElement('div');
  div.className = `msg ${type}`;
  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = type === 'bot' ? '🐼' : '🧑';
  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.textContent = text;
  div.appendChild(avatar);
  div.appendChild(bubble);
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
  const msgs = document.getElementById('gilbert-messages');
  const div = document.createElement('div');
  div.className = 'msg bot'; div.id = 'typing-indicator';
  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar'; avatar.textContent = '🐼';
  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble typing';
  bubble.innerHTML = '<span></span><span></span><span></span>';
  div.appendChild(avatar); div.appendChild(bubble);
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-indicator');
  if (t) t.remove();
}

function sendMessage() {
  const input = document.getElementById('gilbert-input');
  const text = input.value.trim();
  if (!text) return;
  addMsg(text, 'user');
  input.value = '';
  showTyping();
  setTimeout(() => {
    removeTyping();
    addMsg(getResponse(text), 'bot');
  }, 900 + Math.random() * 600);
}

document.getElementById('gilbert-send').addEventListener('click', sendMessage);
document.getElementById('gilbert-input').addEventListener('keydown', e => { if (e.key === 'Enter') sendMessage(); });

// Fade-in on scroll
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; } });
}, { threshold: 0.1 });

document.querySelectorAll('.problem-card, .product-card, .step, .amazon-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  observer.observe(el);
});
</script>
